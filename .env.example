PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slideshow_generator

S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# Optional for S3-compatible providers (MinIO, self-hosted gateway, etc.)
# When S3_ENDPOINT is set, path-style URLs are used by default so requests go to
# https://your-endpoint/bucket/key instead of https://bucket.your-endpoint/key (often no DNS).
S3_ENDPOINT=
# Set to "false" only if your provider exposes virtual-hosted bucket DNS.
S3_FORCE_PATH_STYLE=
S3_PUBLIC_URL_BASE=

# Optional override for frontend requests (defaults to /api)
VITE_API_BASE_URL=/api

# Optional: restore Google login UI
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
